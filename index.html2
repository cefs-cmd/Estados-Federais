    <title>TABELA NOVA</title>

    <style>

      table {
            border-collapse: collapse;
        }

        th {
            background-color: black;
            color: white;
            padding: 8px;
        }

        td {
            padding: 8px;
        }

        /* deixa apenas os 5 primeiros verdes */
        tr:nth-child(-n+6) td {
            background-color: rgb(169, 228, 169);
        }

        th, td {
            border: 1px solid black;
        }

    </style>

</head>
